{
  "manifest_version": 3,
  "name": "Avomos — Suno Metadata Parser",
  "description": "Scan and update metadata from your Suno feed",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://suno.com/*",
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/content-BOR4K5ny.js"
      ],
      "matches": [
        "https://suno.com/*"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/content-B9VxJdA6.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://suno.com/*"
      ],
      "resources": [
        "page-interceptor.js",
        "assets/content-BOR4K5ny.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "action": {
    "default_title": "Avomos"
  },
  "version": "0.3.11"
}
