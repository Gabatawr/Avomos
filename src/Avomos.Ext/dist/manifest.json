{
  "manifest_version": 3,
  "name": "Avomos — Suno Metadata Parser",
  "description": "Scan and update metadata from your Suno feed",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://suno.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.tsx-loader-hZEgQfb0.js"
      ],
      "matches": [
        "https://suno.com/*"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/global-C25KCyIP.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://suno.com/*"
      ],
      "resources": [
        "page-interceptor.js",
        "assets/global-DpuS3zah.js",
        "assets/content.tsx-Df-f1TC-.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "action": {
    "default_title": "Avomos"
  },
  "version": "0.5.1"
}
