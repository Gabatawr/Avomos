{
  "manifest_version": 3,
  "name": "Avomos — Suno Metadata Parser",
  "description": "Scan and update metadata from your Suno feed",
  "browser_specific_settings": {
    "gecko": {
      "id": "avomos@suno.parser",
      "strict_min_version": "113.0"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://suno.com/*",
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://suno.com/*"
      ],
      "js": [
        "src/content.tsx"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-interceptor.js"
      ],
      "matches": [
        "https://suno.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Avomos"
  }
}
